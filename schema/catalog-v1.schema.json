{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kiln-site/bricks/main/schema/catalog-v1.schema.json",
  "title": "Kiln Brick catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "recipes"],
  "properties": {
    "format": { "const": "kiln.catalog/v1" },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
    }
  }
}

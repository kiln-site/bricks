{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kiln-site/bricks/main/schema/recipe-v1.schema.json",
  "title": "Kiln Brick recipe v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "metadata", "variables", "runtime", "network"],
  "properties": {
    "format": { "const": "kiln.brick/v1" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "game", "author"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{0,63}$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "description": { "type": "string", "minLength": 1, "maxLength": 280 },
        "game": { "type": "string", "minLength": 1, "maxLength": 80 },
        "author": { "type": "string", "minLength": 1, "maxLength": 80 },
        "documentation": { "type": "string", "format": "uri", "maxLength": 2048 },
        "tags": {
          "type": "array",
          "maxItems": 12,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,31}$" }
        }
      }
    },
    "variables": {
      "type": "object",
      "maxProperties": 48,
      "propertyNames": { "pattern": "^[a-z][a-z0-9_]{0,47}$" },
      "additionalProperties": { "$ref": "#/$defs/variable" }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "name", "environment", "resources", "storage"],
      "properties": {
        "image": { "type": "string", "minLength": 1, "maxLength": 512 },
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "environment": {
          "type": "object",
          "maxProperties": 96,
          "propertyNames": { "pattern": "^[A-Z_][A-Z0-9_]*$" },
          "additionalProperties": { "type": "string", "maxLength": 8192 }
        },
        "entrypoint": {
          "type": "array",
          "maxItems": 32,
          "items": { "type": "string", "maxLength": 2048 }
        },
        "command": {
          "type": "array",
          "maxItems": 64,
          "items": { "type": "string", "maxLength": 2048 }
        },
        "workingDirectory": { "type": "string", "pattern": "^/", "maxLength": 256 },
        "stopSignal": { "type": "string", "pattern": "^SIG[A-Z0-9]+$" },
        "user": { "type": "string", "pattern": "^[0-9]+(?::[0-9]+)?$" },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["memory"],
          "properties": {
            "memory": { "type": "string", "minLength": 1, "maxLength": 128 },
            "memoryReservation": { "type": "string", "minLength": 1, "maxLength": 128 },
            "pids": { "type": "integer", "minimum": 16, "maximum": 32768, "default": 512 }
          }
        },
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mount"],
          "properties": {
            "mount": { "type": "string", "pattern": "^/", "maxLength": 256 }
          }
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "primaryPort", "ports"],
      "properties": {
        "mode": { "enum": ["minecraft-backend", "minecraft-proxy", "direct"] },
        "primaryPort": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,31}$" },
        "hostname": { "type": "string", "minLength": 1, "maxLength": 256 },
        "ports": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/port" }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "architectures": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["amd64", "arm64"] }
        },
        "singleton": { "type": "boolean", "default": false }
      }
    }
  },
  "$defs": {
    "scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" }
      ]
    },
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label", "description", "required"],
      "properties": {
        "type": { "enum": ["string", "number", "boolean"] },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "description": { "type": "string", "minLength": 1, "maxLength": 280 },
        "required": { "type": "boolean" },
        "sensitive": { "type": "boolean", "default": false },
        "default": { "$ref": "#/$defs/scalar" },
        "options": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/scalar" }
        },
        "rules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pattern": { "type": "string", "maxLength": 512 },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "minLength": { "type": "integer", "minimum": 0, "maximum": 8192 },
            "maxLength": { "type": "integer", "minimum": 1, "maximum": 8192 }
          }
        }
      }
    },
    "port": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "container", "protocol"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,31}$" },
        "container": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "protocol": { "enum": ["tcp", "udp"] },
        "host": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    }
  }
}
